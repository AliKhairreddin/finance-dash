# App
PORT=8787
VITE_API_BASE=/api
VITE_CONVEX_URL=https://fabulous-elephant-597.convex.cloud
CONVEX_URL=https://fabulous-elephant-597.convex.cloud
CONVEX_DEPLOYMENT=dev:fabulous-elephant-597
CONVEX_SERVICE_TOKEN=

# OpenRouter AI
# Keep this in the runtime environment; it is never stored in dashboard state.
OPENROUTER_API_KEY=

# Wise Platform
# Docs: https://docs.wise.com/
WISE_API_TOKEN=
WISE_PROFILE_ID=
WISE_ENVIRONMENT=production
# Optional comma-separated balanceId:currency pairs, for example: 64:USD,65:CAD
WISE_BALANCE_IDS=

# Revolut Business API
# Docs: https://developer.revolut.com/docs/business/business-api
REVOLUT_ENVIRONMENT=production
REVOLUT_REFRESH_TOKEN=
REVOLUT_CLIENT_ASSERTION_JWT=

# Slash beta API
# Docs: https://docs.slash.com/
SLASH_API_KEY=
SLASH_LEGAL_ENTITY_ID=
SLASH_BASE_URL=https://api.slash.com

# American Express Account and Transaction API
# Docs: https://developer.americanexpress.com/products/account-and-transaction-api-public/overview
AMEX_TOKEN_URL=
AMEX_API_BASE_URL=
AMEX_CLIENT_ID=
AMEX_CLIENT_SECRET=
AMEX_REFRESH_TOKEN=
# Comma-separated accountId:name:currency entries, for example: acct_123:Amex Platinum:USD
AMEX_ACCOUNT_IDS=
AMEX_ACCOUNT_PATH_TEMPLATE=
AMEX_TRANSACTIONS_PATH_TEMPLATE=

# Merit invoices
# Docs: https://api.merit.ee/connecting-robots/reference-manual/
MERIT_API_BASE_URL=https://aktiva.merit.ee/api
MERIT_GET_INVOICES_PATH=/v1/getinvoices
MERIT_CREATE_INVOICE_PATH=/v2/sendinvoice
MERIT_API_ID=
MERIT_API_KEY=
# Hard safety gate. Set true only when explicit, user-confirmed invoice sending is approved.
MERIT_WRITES_ENABLED=false
MERIT_DEFAULT_ITEM_CODE=SERVICES
MERIT_DEFAULT_COUNTRY_CODE=CA

# Partner revenue
# TUNE Affiliate API / HasOffers: https://developers.tune.com/affiliate
REVENUE_TIMEZONE=UTC
KISSTERRA_TUNE_NETWORK_ID=
KISSTERRA_TUNE_API_KEY=
# Optional override. Defaults to https://{networkId}.api.hasoffers.com/Apiv3/json
KISSTERRA_TUNE_API_BASE_URL=
