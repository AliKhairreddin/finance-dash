# App
PORT=8787
VITE_API_BASE=/api

# Wise Platform
# Docs: https://docs.wise.com/
WISE_API_TOKEN=
WISE_PROFILE_ID=
WISE_ENVIRONMENT=sandbox
# Optional comma-separated balanceId:currency pairs, for example: 64:USD,65:CAD
WISE_BALANCE_IDS=

# Slash beta API
# Docs: https://docs.slash.com/
SLASH_API_KEY=
SLASH_LEGAL_ENTITY_ID=
SLASH_BASE_URL=https://api.slash.com

# QuickBooks Online
# Docs: https://developer.intuit.com/app/developer/qbo/docs/develop
QUICKBOOKS_ENVIRONMENT=sandbox
QUICKBOOKS_CLIENT_ID=
QUICKBOOKS_CLIENT_SECRET=
QUICKBOOKS_REFRESH_TOKEN=
QUICKBOOKS_ACCESS_TOKEN=
QUICKBOOKS_REALM_ID=
QUICKBOOKS_INCOME_ITEM_ID=1
QUICKBOOKS_INCOME_ITEM_NAME=Services

# Optional unknown "Merit" connector.
# Fill these only if the Merit product you use exposes a REST API.
MERIT_API_BASE_URL=
MERIT_API_KEY=
